{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.diablo4-build-optimizer/schemas/runtime-cadence-observations.schema.json",
  "title": "Diablo IV Runtime Cadence Observations",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mode",
    "currentBuild",
    "assetId",
    "actorSnoId",
    "aiBehaviorSnoId",
    "sessions"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "mode": { "const": "runtime-cadence-observation-v1" },
    "currentBuild": { "type": "string", "minLength": 1 },
    "assetId": { "type": "integer", "minimum": 1 },
    "actorSnoId": { "type": "integer", "minimum": 1 },
    "aiBehaviorSnoId": { "type": "integer", "minimum": 1 },
    "notes": { "type": "array", "items": { "type": "string" } },
    "sessions": {
      "type": "array",
      "items": { "$ref": "#/$defs/session" }
    }
  },
  "$defs": {
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "scenarioId",
        "sourceFile",
        "captureFps",
        "attackSpeedState",
        "buildState",
        "events"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "scenarioId": {
          "enum": [
            "baseline-sequence",
            "blast-of-bile-single-breath",
            "attack-speed-scaling"
          ]
        },
        "sourceFile": { "type": ["string", "null"] },
        "captureFps": { "type": "number", "minimum": 1 },
        "attackSpeedState": {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "attacksPerSecond", "modifiers"],
          "properties": {
            "label": { "type": "string", "minLength": 1 },
            "attacksPerSecond": { "type": ["number", "null"], "exclusiveMinimum": 0 },
            "modifiers": { "type": "array", "items": { "type": "string" } }
          }
        },
        "buildState": {
          "type": "object",
          "additionalProperties": false,
          "required": ["blastOfBile", "attackSpeedStableWithinCast", "otherSkillModifiers"],
          "properties": {
            "blastOfBile": { "type": "boolean" },
            "attackSpeedStableWithinCast": { "type": "boolean" },
            "otherSkillModifiers": { "type": "array", "items": { "type": "string" } }
          }
        },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/event" }
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observedAtSeconds", "eventKind", "attackKind", "damageInstanceCount", "notes"],
      "properties": {
        "observedAtSeconds": { "type": "number", "minimum": 0 },
        "sourceFrame": { "type": ["integer", "null"], "minimum": 0 },
        "eventKind": {
          "enum": [
            "cast-start",
            "spawn-contact",
            "attack-start",
            "attack-contact",
            "damage-instance",
            "despawn"
          ]
        },
        "attackKind": { "enum": ["none", "projectile", "breath", "unknown"] },
        "damageInstanceCount": { "type": ["integer", "null"], "minimum": 0 },
        "notes": { "type": ["string", "null"] }
      }
    }
  }
}
